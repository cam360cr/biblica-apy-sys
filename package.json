{
  "name": "hcb-basicos-app",
  "version": "1.0.0",
  "description": "Sistema web para registrar consumos de basicos con la API de Clinica Biblica",
  "main": "hcb-basicos-app/server.js",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "start": "node hcb-basicos-app/server.js",

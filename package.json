    "express": "^4.21.2",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "pg": "^8.21.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "xlsx": "^0.18.5"
  }
}
